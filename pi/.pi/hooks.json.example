{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": "./hooks/format.sh",
        "matcher": "\\.(ts|tsx|js|jsx)$",
        "timeout": 15
      }
    ],
    "beforeShellExecution": [
      {
        "command": "./hooks/block-dangerous.sh",
        "matcher": "rm\\s+(-rf|--recursive)|sudo|chmod.*777"
      }
    ],
    "stop": [
      {
        "command": "./hooks/notify.sh"
      }
    ]
  }
}
