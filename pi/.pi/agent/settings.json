{
  "lastChangelogVersion": "0.54.2",
  "defaultProvider": "google-gemini-cli",
  "defaultModel": "gemini-3-flash-preview",
  "defaultThinkingLevel": "off",
  "theme": "tokyo-night",
  "packages": [
    "npm:pi-mcp-adapter",
    "npm:pi-subagents",
    "npm:pi-mermaid",
    "npm:@aliou/pi-guardrails"
  ],
  "hideThinkingBlock": true,
  "notification": {
    "enabled": true,
    "sound": {
      "enabled": true,
      "player": "auto"
    },
    "toast": {
      "enabled": false
    },
    "events": {
      "agentEnd": true,
      "sessionStart": true
    }
  }
}